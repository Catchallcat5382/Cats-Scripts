-- ── EXECUTOR HTTP ─────────────────────────────────────────
local function httpPost(url, headers, body)
    local fn = (syn and syn.request)
            or (http and http.request)
            or (typeof(request)=="function" and request)
            or (typeof(http_request)=="function" and http_request)
            or (fluxus and fluxus.request)
    if not fn then return nil, "No HTTP function found" end
    local ok, resp = pcall(fn, {Url=url,Method="POST",Headers=headers,Body=body})
    if not ok then return nil, tostring(resp) end
    return resp, nil
end

-- ── CONVERSATION MEMORY ───────────────────────────────────
local conversationHistory = {}
local function getHistory(uid)
    if not conversationHistory[uid] then conversationHistory[uid]={} end
    return conversationHistory[uid]
end
local function addToHistory(uid, role, content)
    local h = getHistory(uid)
    table.insert(h, {role=role,content=content})
    while #h > MAX_HISTORY do table.remove(h,1) end
end

-- ── GROQ API CALL ─────────────────────────────────────────
-- NOTE: systemPrompt is passed in at call time so live SysBox.Text is always used
local function callGroq(apiKey, systemPrompt, userId, senderName, userMessage)
    if not apiKey or apiKey=="" then return nil,"NO_KEY" end
    addToHistory(userId,"user", senderName.." says: "..userMessage)
    local messages = {{role="system", content=systemPrompt..GRAMMAR_SUFFIX}}
    for _,e in ipairs(getHistory(userId)) do table.insert(messages,e) end
    local ok, body = pcall(HttpService.JSONEncode, HttpService, {
        model=selectedModel, max_tokens=150, messages=messages,
    })
    if not ok then return nil,"JSON_ENCODE" end
    local resp, err = httpPost(GROQ_URL, {
        ["Content-Type"]="application/json",
        ["Authorization"]="Bearer "..apiKey,
    }, body)
    if not resp then
        local h=getHistory(userId); if #h>0 then table.remove(h,#h) end
        return nil,err
    end
    if resp.StatusCode==429 then return nil,"RATE_LIMITED" end
    if resp.StatusCode==401 then return nil,"BAD_KEY" end
    if resp.StatusCode~=200 then
        local h=getHistory(userId); if #h>0 then table.remove(h,#h) end
        local msg="HTTP_"..tostring(resp.StatusCode)
        pcall(function()
            local d=HttpService:JSONDecode(resp.Body)
            if d.error and d.error.message then msg=msg..": "..d.error.message end
        end)
        return nil,msg
    end
    local ok2,data=pcall(HttpService.JSONDecode,HttpService,resp.Body)
    if not ok2 then return nil,"JSON_DECODE" end
    local reply=data.choices[1].message.content
    addToHistory(userId,"assistant",reply)
    return reply,nil
end

