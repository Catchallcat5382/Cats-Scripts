-- ── TOGGLE BUILDER ────────────────────────────────────────
local function makeToggle(track,thumb,onColor,onFn,offFn)
    local state=false
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType~=Enum.UserInputType.MouseButton1 then return end
        state=not state
        if state then
            tw(track,fast,{BackgroundColor3=onColor})
            tw(thumb,fast,{Position=UDim2.new(0,23,0.5,-9),BackgroundColor3=C.ACCENT})
            if onFn then onFn() end
        else
            tw(track,fast,{BackgroundColor3=Color3.fromRGB(35,45,90)})
            tw(thumb,fast,{Position=UDim2.new(0,3,0.5,-9),BackgroundColor3=C.DIMTEXT})
            if offFn then offFn() end
        end
    end)
    return function() return state end
end

