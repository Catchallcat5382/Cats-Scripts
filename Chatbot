-- ── PROCESS QUEUE ─────────────────────────────────────────
local playerLastSent={}
local function processQueue()
    if queueRunning then return end; queueRunning=true
    task.spawn(function()
        while #messageQueue>0 and not isShutdown and Gui.Parent do
            while groqPaused and not isShutdown and Gui.Parent do task.wait(1) end
            if isShutdown or not Gui.Parent then break end
            local item=table.remove(messageQueue,1)
            local player=item.player; local message=item.message
            local apiKey=item.apiKey; local sysPrompt=item.sysPrompt; local userId=item.userId
            local uid=player.UserId
            if playerLastSent[uid] then
                local w=COOLDOWN-(tick()-playerLastSent[uid]); if w>0 then task.wait(w) end
            end
            if isShutdown then break end
            updateQueueBadge(); addLog(player.Name,message,"user")
            if FooterText.Parent then FooterText.Text=player.Name..": "..message:sub(1,40) end
            startThinking()
            -- ★ sysPrompt is captured at queue time from SysBox.Text, so it's always live
            local reply,err=callGroq(apiKey,sysPrompt,userId,player.Name,message)
            stopThinking(); playerLastSent[uid]=tick()
            if isShutdown then break end
            if reply then
                addLog("Groq",reply,"ai")
                if FooterText.Parent then FooterText.Text="Replied to "..player.Name.."." end
                if sendToChat then sendRobloxChat(player.Name,reply) end
            elseif err=="RATE_LIMITED" then
                addLog("","Groq rate limited. Pausing 60s.","sys")
                setGroqRateLimited(60); table.insert(messageQueue,1,item)
            elseif err=="BAD_KEY" then
                addLog("","Invalid API key. Check console.groq.com.","sys")
                if FooterText.Parent then FooterText.Text="Bad API key." end; break
            else
                addLog("","Error: "..tostring(err),"sys")
                if FooterText.Parent then FooterText.Text="Error. Check key or quota." end
            end
            task.wait(0.5)
        end
        queueRunning=false
        if not isShutdown and FooterText.Parent and #messageQueue==0 then
            FooterText.Text="Waiting for messages."
        end
    end)
end

-- ── CHAT HANDLER ──────────────────────────────────────────
local function handleChat(player,message)
    if isShutdown or not autoRespond then return end
    local isSelf=(player==LocalPlayer)
    if isSelf and not respondSelf then return end
    local apiKey=KeyBox.Text
    if apiKey=="" then addLog("","No API key set.","sys"); return end
    if not respondAll then
        local trigger=TriggerBox.Text:lower():gsub("%s+","")
        if trigger~="" and not message:lower():find(trigger,1,true) then return end
    end
    if shouldBlock(message) then
        addLog(player.Name,message,"user"); addLog("Groq",BLOCKED_RESPONSE,"ai")
        if sendToChat then sendRobloxChat(player.Name,BLOCKED_RESPONSE) end; return
    end
    -- ★ Capture SysBox.Text RIGHT NOW so each message uses the current prompt
    table.insert(messageQueue,{
        player=player, message=message,
        apiKey=apiKey,
        sysPrompt=SysBox.Text,   -- ← live capture
        userId=player.UserId,
    })
    updateQueueBadge(); processQueue()
end

