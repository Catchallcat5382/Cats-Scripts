local function setGroqRateLimited(seconds)
    groqPaused=true; groqRetryAt=tick()+(seconds or 60)
    tw(StatusDot,fast,{BackgroundColor3=C.RED}); tw(StatusLbl,fast,{TextColor3=C.RED})
    StatusLbl.Text="PAUSED"
    local t=task.spawn(function()
        while groqPaused and not isShutdown and Gui.Parent do
            local r=math.ceil(groqRetryAt-tick()); if r<=0 then break end
            if FooterText.Parent then FooterText.Text="Groq rate limited. Resuming in "..r.."s." end
            task.wait(1)
        end
        if not isShutdown and Gui.Parent then
            groqPaused=false
            if autoRespond then
                tw(StatusDot,fast,{BackgroundColor3=C.GREEN}); tw(StatusLbl,fast,{TextColor3=C.GREEN})
                StatusLbl.Text="ACTIVE"
                if FooterText.Parent then FooterText.Text="Resumed." end
            else
                tw(StatusDot,fast,{BackgroundColor3=Color3.fromRGB(120,130,160)}); tw(StatusLbl,fast,{TextColor3=C.DIMTEXT})
                StatusLbl.Text="OFF"
            end
        end
    end)
    onCleanup(function() task.cancel(t) end)
end

