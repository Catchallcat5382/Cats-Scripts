local BLOCKED_RESPONSE="Sorry, I can't answer that. Please try asking something else!"
local function vim_escape(s) return s:gsub("([%(%)%.%%%+%-%*%?%[%^%$])","%%%1") end
local BAD_WORDS={
    "fuck","shit","bitch","cunt","dick","cock","pussy","bastard","piss",
    "slut","whore","fag","nigga","nigger","retard","kys","kms",
    "porn","sex","nude","naked","nsfw","hentai","rape","molest",
    "pedophile","pedo","loli","kill yourself","shoot up","stab","murder",
    "cocaine","heroin","meth","fentanyl","crack",
}
local CHAR_MAP={["@"]="a",["4"]="a",["3"]="e",["1"]="i",["!"]="i",["0"]="o",["5"]="s",["$"]="s",["7"]="t"}
local function normalize(msg)
    local s=msg:lower()
    for c,r in pairs(CHAR_MAP) do s=s:gsub(vim_escape(c),r) end
    s=s:gsub("[%s%.%-_*,;:!?/\\|]",""):gsub("(.)%1+","%1")
    return s
end
local function containsBadWord(msg)
    local n=normalize(msg); local l=msg:lower():gsub("[%s%.%-_*]","")
    for _,w in ipairs(BAD_WORDS) do
        if n:find(normalize(w),1,true) then return true end
        if l:find(w:gsub("%s",""),1,true) then return true end
    end
    return false
end
local function shouldBlock(msg) return msg:match("^[%s#]+$")~=nil or containsBadWord(msg) end

