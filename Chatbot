-- ── TUTORIAL ALIGNMENT ENGINE ────────────────────────────
-- A single RenderStepped connection runs for the lifetime of one step.
-- It re-reads AbsolutePosition/Size every frame so the spotlight and card
-- are always pixel-perfect even if the panel animates or the viewport resizes.
local alignConn = nil  -- current per-step RenderStepped connection

local CARD_W = 320
local CARD_H = 240
local CARD_PAD = 28   -- gap between spotlight bottom edge and card top

local function getViewport()
    return workspace.CurrentCamera.ViewportSize
end

-- Clamp a value so the card stays fully on screen
local function clampX(x) return math.max(4, math.min(x, getViewport().X - CARD_W - 4)) end
local function clampY(y) return math.max(4, math.min(y, getViewport().Y - CARD_H - 4)) end

local function applyPosition(step)
    local highlight = step.highlight
    local target    = highlight and TUT_HIGHLIGHTS[highlight]
    local side      = step.side or "center"

    if target and target.Parent and side ~= "center" then
        local ap  = target.AbsolutePosition
        local as  = target.AbsoluteSize

        -- Guard: panel still collapsed/animating — skip this frame
        if as.X < 10 or as.Y < 2 then return end

        local vp  = getViewport()
        local pad = 8

        -- Spotlight wraps the highlighted element
        TutSpot.Visible  = true
        TutSpot.Position = UDim2.new(0, ap.X - pad, 0, ap.Y - pad)
        TutSpot.Size     = UDim2.new(0, as.X + pad*2, 0, as.Y + pad*2)

        -- Card goes to the left of the panel
        local panelAP = Panel.AbsolutePosition
        local cardX   = panelAP.X - CARD_W - 16
        -- If not enough space on left, go right
        if cardX < 4 then
            cardX = panelAP.X + Panel.AbsoluteSize.X + 16
        end
        cardX = math.max(4, math.min(cardX, vp.X - CARD_W - 4))

        -- Card Y: vertically aligned with the center of the highlighted element
        local elemCenterY = ap.Y + as.Y * 0.5
        local cardY = elemCenterY - CARD_H * 0.5
        cardY = math.max(4, math.min(cardY, vp.Y - CARD_H - 4))

        TutCard.Position = UDim2.new(0, cardX, 0, cardY)
    else
        -- No highlight: centre card on screen
        TutSpot.Visible  = false
        local vp = getViewport()
        local cx = math.max(4, math.min((vp.X - CARD_W) * 0.5, vp.X - CARD_W - 4))
        local cy = math.max(4, math.min((vp.Y - CARD_H) * 0.5, vp.Y - CARD_H - 4))
        TutCard.Position = UDim2.new(0, cx, 0, cy)
    end
end

local function stopAlignLoop()
    if alignConn then alignConn:Disconnect(); alignConn = nil end
end

local function startAlignLoop(step)
    stopAlignLoop()
    local snapKey  = step.highlight
    local snapSide = step.side or "center"
    local snapInfo = snapKey and TUT_HIGHLIGHTS[snapKey]

    alignConn = RunService.RenderStepped:Connect(function()
        if not tutorialActive then stopAlignLoop(); return end

        local vp  = getViewport()
        local pad = 8

        if snapInfo and snapSide ~= "center" then
            local obj      = snapInfo.obj
            local panelOffY = snapInfo.panelY
            local panelAP  = Panel.AbsolutePosition
            local panelAS  = Panel.AbsoluteSize

            -- Guard: panel still collapsed
            if panelAS.Y < 10 then return end

            -- Compute element screen position from known panel-relative offset
            -- Use AbsoluteSize from the actual object (reliable), Y from panel offset
            local elemScreenY = panelAP.Y + panelOffY
            local elemH       = obj.AbsoluteSize.Y
            if elemH < 2 then elemH = 34 end  -- fallback height

            local elemScreenX = panelAP.X + 12  -- elements have 12px left margin

            -- Spotlight
            TutSpot.Visible  = true
            TutSpot.Position = UDim2.new(0, elemScreenX - pad, 0, elemScreenY - pad)
            TutSpot.Size     = UDim2.new(0, panelAS.X - 24 + pad*2, 0, elemH + pad*2)

            -- Card: left of panel (right fallback)
            local cardX = panelAP.X - CARD_W - 16
            if cardX < 4 then cardX = panelAP.X + panelAS.X + 16 end
            cardX = math.max(4, math.min(cardX, vp.X - CARD_W - 4))

            -- Card Y: centred on element
            local elemCenterY = elemScreenY + elemH * 0.5
            local cardY = math.max(4, math.min(elemCenterY - CARD_H * 0.5, vp.Y - CARD_H - 4))

            TutCard.Position = UDim2.new(0, cardX, 0, cardY)
        else
            TutSpot.Visible = false
            local cx = math.max(4, math.min((vp.X - CARD_W) * 0.5, vp.X - CARD_W - 4))
            local cy = math.max(4, math.min((vp.Y - CARD_H) * 0.5, vp.Y - CARD_H - 4))
            TutCard.Position = UDim2.new(0, cx, 0, cy)
        end
    end)
end

