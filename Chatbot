local function sendRobloxChat(targetUsername,reply)
    if isShutdown then return end
    if not canSendRobloxChat() then
        task.spawn(function()
            while not canSendRobloxChat() and not isShutdown do task.wait(1) end
            if not isShutdown then sendRobloxChat(targetUsername,reply) end
        end); return
    end
    local r=reply; if #r>0 then r=r:sub(1,1):lower()..r:sub(2) end
    local msg="[AI]: "..targetUsername..", "..r
    if #msg>200 then msg=msg:sub(1,197).."..." end
    pcall(function()
        local tcs=game:GetService("TextChatService")
        local ch=tcs.TextChannels:FindFirstChild("RBXGeneral")
        if ch then ch:SendAsync(msg); recordRobloxSend() end
    end)
end

