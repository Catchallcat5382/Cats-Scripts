    L('txt+="["+m.time+"] "+who+"\\n"+m.message+"\\n\\n";});')
    L('var b=new Blob([txt],{type:"text/plain"});var a=document.createElement("a");')
    L('a.href=URL.createObjectURL(b);a.download="transcript-'..snapshot.id..'.txt";a.click();};')
    L('})();</script></body></html>')
    return table.concat(lines,"\n")
end

local function buildDataURI(html)
