local function showTutStep(n)
    tutStep = n
    local step = TUTORIAL_STEPS[n]
    if not step then closeTutorial(); return end

    TutStepLbl.Text  = tostring(n).." / "..tostring(#TUTORIAL_STEPS)
    TutTitleLbl.Text = step.title
    TutBodyLbl.Text  = step.body

    local pct = (n - 1) / (#TUTORIAL_STEPS - 1)
    tw(TutProgressFill, fast, {Size=UDim2.new(pct, 0, 1, 0)})

    if step.image then
        TutImgFrame.Visible = true
        TutImg.Image        = step.image
        TutImgCaption.Text  = step.imageCaption or ""
    else
        TutImgFrame.Visible = false
    end

    if step.link then
        TutLinkBtn.Visible    = true
        TutLinkBtn.Text       = step.linkLabel or ("🔗 "..step.link)
        TutLinkBtn.TextColor3 = C.ACCENT
        tutCurrentLink        = step.link
    else
        TutLinkBtn.Visible = false
        tutCurrentLink     = ""
    end

    TutPrevBtn.Visible = n > 1
    if n == #TUTORIAL_STEPS then
        TutNextBtn.Text             = "✓ Done!"
        TutNextBtn.BackgroundColor3 = C.GREEN
    else
        TutNextBtn.Text             = "Next →"
        TutNextBtn.BackgroundColor3 = C.YELLOW
    end

    TutCard.Size = UDim2.new(0, CARD_W, 0, CARD_H)
    TutBodyScroll.CanvasPosition = Vector2.new(0, 0)

    startAlignLoop(step)
end

local function startTutorial()
    if tutorialActive then return end
    tutorialActive = true

    -- CRITICAL: cancel any in-progress tween on Panel and force it to full size
    -- RIGHT NOW so that child AbsolutePositions are valid this frame.
    -- We do this by stopping any running tween via a zero-duration tween,
    -- then setting the size directly.
    TweenService:Create(Panel, TweenInfo.new(0), {
        Size               = UDim2.new(0, 370, 0, PANEL_H),
        BackgroundTransparency = 0,
    }):Play()
    Panel.Visible = true
    -- Also reset the toggle button colour to "open" state
    tw(ToggleBtn, fast, {BackgroundColor3=Color3.fromRGB(30,50,120)})
    panelOpen = true

    TutOverlay.Visible             = true
    TutOverlay.BackgroundTransparency = 0.6
    TutCard.Visible                = true
    TutCard.BackgroundTransparency = 0

    -- Pulsing glow on spotlight border
    if spotGlowThread then task.cancel(spotGlowThread) end
    spotGlowThread = task.spawn(function()
        while tutorialActive and not isShutdown do
            tw(TutSpotStroke, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Thickness=5, Transparency=0.4})
            task.wait(0.8)
            if not tutorialActive then break end
            tw(TutSpotStroke, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Thickness=2, Transparency=0})
            task.wait(0.8)
        end
    end)

    -- Wait 2 RenderStepped frames so Roblox has fully laid out the panel
    -- and all child AbsolutePosition/Size values are correct before we read them.
    local frameCount = 0
    local waitConn
    waitConn = RunService.RenderStepped:Connect(function()
        frameCount += 1
        if frameCount >= 2 then
            waitConn:Disconnect()
            if tutorialActive then
                showTutStep(1)
            end
        end
    end)
end

TutNextBtn.MouseButton1Click:Connect(function()
    if tutStep>=#TUTORIAL_STEPS then closeTutorial()
    else showTutStep(tutStep+1) end
end)
TutPrevBtn.MouseButton1Click:Connect(function()
    if tutStep>1 then showTutStep(tutStep-1) end
end)
TutSkipBtn.MouseButton1Click:Connect(closeTutorial)
TutBtn.MouseButton1Click:Connect(startTutorial)

