        for _,e in ipairs(snapshot.entries) do
            local cls="msg-"..e.kind; local spCls="sp-"..e.kind
            local spLabel = e.kind=="ai" and "✦ GROQ" or e.kind=="sys" and "⚙ SYSTEM" or "👤 "..tostring(e.speaker)
            local safe=e.message:gsub("&","&amp;"):gsub("<","&lt;"):gsub(">","&gt;"):gsub('"','&quot;')
            L('<div class="msg '..cls..'"><span class="ts">'..e.time..'</span>')
            L('<div class="speaker '..spCls..'">'..spLabel..'</div>')
            L('<div class="text">'..safe..'</div></div>')
        end
