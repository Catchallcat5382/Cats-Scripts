    L('<footer>Generated by Groq Chat Responder • '..snapshot.id..'</footer></div>')
    L('<script>(function(){')
    L('var msgs='..HttpService:JSONEncode(snapshot.entries)..';')
    L('document.getElementById("dlbtn").onclick=function(){')
    L('var txt="GROQ CHAT TRANSCRIPT — '..snapshot.id..'\\nLabel: '..snapshot.label..'\\nMessages: '..tostring(#snapshot.entries)..'\\n\\n"+"=".repeat(60)+"\\n\\n";')
